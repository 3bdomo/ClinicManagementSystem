## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Bb]uild/
[Bb]uilds/
x64/
x86/
[Aa]ny [Cc]pu/
[Cc]pu [Aa]ny/
[Ll]ogs/

# Visual Studio cache/options directories
.vs/
.vscode/
.idea/
.cache/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet
*.nupkg
*.snupkg
*.nuspec
**/packages/*
!**/packages/build/
!**/packages/repositories.config
nuget.config

# DotCover
*.dotCover

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish output
**/wwwroot/lib/
**/wwwroot/css/*.min.css
**/wwwroot/js/*.min.js
**/wwwroot/js/*.map
publish/
**/Properties/PublishProfiles/*.user

# SQL Server files
*.mdf
*.ldf
*.ndf

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Rider
.idea/

# Azure
*.azurePubxml
*.publishsettings

# VS Code local history
.history/

# node_modules (if using frontend tooling)
node_modules/

# Local secrets
secrets.json
appsettings.Development.json
appsettings.Local.json
